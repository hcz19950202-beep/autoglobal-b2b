# ===== Railway 部署时在 Dashboard 中设置这些环境变量 =====

# MongoDB Atlas 连接串（免费版）
# 去 https://www.mongodb.com/atlas 注册，创建免费集群后获取
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/used-car-b2b?retryWrites=true&w=majority

# JWT 密钥（随便写一个复杂字符串）
JWT_SECRET=your_jwt_secret_key_change_in_production_1a2b3c4d

# 前端域名（Vercel 分配的域名）
FRONTEND_URL=https://your-site.vercel.app

# Railway 会自动注入 PORT，不需要手动设置
# PORT=5000

# Cloudflare R2 图片存储
# 去 Cloudflare Dashboard → R2 → Create Bucket → 获取以下信息
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=autoglobal-images
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
